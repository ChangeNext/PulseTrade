APP_NAME=PulseTrade
ENVIRONMENT=development

# 안전 기본값. KIS 모의투자 주문을 사용하려면 PAPER로 변경합니다.
TRADING_MODE=SIM
ENABLE_LIVE_TRADING=false

KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NUMBER=
KIS_ACCOUNT_PRODUCT_CODE=01
KIS_BASE_URL=https://openapivts.koreainvestment.com:29443
KIS_WEBSOCKET_URL=

DATABASE_URL=sqlite+aiosqlite:///./pulsetrade.db
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

MAX_ORDER_AMOUNT_KRW=100000
MAX_DAILY_LOSS_KRW=50000
MAX_DAILY_ORDERS=5
MAX_POSITION_AMOUNT_KRW=300000

# 쉼표로 구분한 국내주식 6자리 코드. 비어 있으면 자동매매는 준비되지 않습니다.
STRATEGY_SYMBOLS=005930
AUTO_ORDER_BUDGET_KRW=100000
STRATEGY_STOP_LOSS_PCT=-1.0
STRATEGY_TAKE_PROFIT_PCT=2.0
STRATEGY_VOLUME_MULTIPLIER=2.0
SIGNAL_BUY_THRESHOLD=70
SIGNAL_SELL_THRESHOLD=-60
SIGNAL_EXIT_THRESHOLD=-80
SIGNAL_WEIGHT_ORB=25
SIGNAL_WEIGHT_VOLUME=20
SIGNAL_WEIGHT_VWAP=15
SIGNAL_WEIGHT_ORDERBOOK=15
SIGNAL_WEIGHT_TRADE_STRENGTH=15
SIGNAL_WEIGHT_MOMENTUM=10
ORDER_RECONCILE_INTERVAL_SECONDS=3.0
SIM_INITIAL_CASH_KRW=10000000
SIM_COMMISSION_BPS=1.5
SIM_SELL_TAX_BPS=18.0
SIM_LATENCY_MS=150
MAX_SPREAD_BPS=20
MAX_QUOTE_AGE_SECONDS=2
VOLATILITY_GUARD_MOVE_PCT=2
VOLATILITY_GUARD_COOLDOWN_SECONDS=120
STRATEGY_ORDER_TTL_SECONDS=3
STRATEGY_MAX_REPRICES=2
STRATEGY_MAX_HOLDING_MINUTES=30
STRATEGY_FORCE_EXIT_TIME=151500
